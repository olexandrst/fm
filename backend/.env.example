# ── Azure OpenAI (обов'язково) ───────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-01
# Основна модель (інтерв'ю) та допоміжна (структуризація/документи):
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_DEPLOYMENT2=gpt-4o

# ── Azure Speech (необов'язково — для голосу STT/TTS) ─────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_TTS_VOICE=uk-UA-PolinaNeural
AZURE_TTS_RATE=1.0
AZURE_STT_LANG=uk-UA

# ── Підписи моделей для інтерфейсу (необов'язково) ────────────────────────
MODEL_LABEL=
MODEL2_LABEL=

# ── Порт ──────────────────────────────────────────────────────────────────
PORT=8000

# ── TLS / корпоративний проксі (необов'язково) ────────────────────────────
# За замовчуванням бекенд бере довірені CA із системного сховища ОС
# (truststore) — у корпоративній мережі цього зазвичай достатньо.
# Якщо потрібно — вкажіть власний кореневий сертифікат компанії:
# AZURE_CA_BUNDLE=C:\certs\corp-root-ca.pem
# Крайній випадок (ЛИШЕ дев/тест): вимкнути перевірку TLS:
# INSECURE_SKIP_TLS_VERIFY=0
